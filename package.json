{
  "name": "obsidian",
  "version": "0.4.3",
  "description": "Open source security scanner for authorised penetration testing",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "release": "electron-builder --publish always"
  },
  "build": {
    "appId": "uk.obsidian.scanner",
    "productName": "OBSIDIAN",
    "directories": { "output": "dist" },
    "publish": {
      "provider": "github",
      "owner": "happygream",
      "repo": "OBSIDIAN"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "icon": "assets/icon.png"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "extraResources": [
      { "from": "assets/", "to": "assets/" },
      { "from": "profiles/", "to": "profiles/" }
    ],
    "fileAssociations": [],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  },
  "keywords": ["security", "scanner", "pentest", "nmap", "nuclei"],
  "author": "Obsidian Contributors",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "electron-updater": "^6.1.0"
  },
  "dependencies": {
    "ws": "^8.16.0",
    "tree-kill": "^1.2.2",
    "electron-updater": "^6.1.0"
  }
}
